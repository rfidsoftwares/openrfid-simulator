{
  "$schema": "../node_modules/@tauri-apps/cli/schema.json",
  "build": {
    "beforeBuildCommand": "pnpm build",
    "beforeDevCommand": "pnpm dev",
    "devPath": "http://localhost:5173",
    "distDir": "../dist"
  },
  "package": {
    "productName": "OpenRFID Simulator",
    "version": "1.0.0"
  },
  "tauri": {
    "allowlist": {
      "all": true
    },
    "bundle": {
      "active": true,
      "category": "Developer Tool",
      "copyright": "Copyright (c) 2026 RFIDSoftwares - https://rfidsoftwares.com",
      "externalBin": [
        "binaries/hopeland-runner"
      ],
      "icon": [
        "icons/32x32.png",
        "icons/128x128.png",
        "icons/128x128@2x.png",
        "icons/icon.icns",
        "icons/icon.ico"
      ],
      "identifier": "com.rfidsoftwares.openrfid",
      "longDescription": "The Open Source RFID Reader Simulator for Developers by RFIDSoftwares.",
      "publisher": "RFID Software India Private Limited",
      "shortDescription": "OpenRFID Simulator Desktop App",
      "targets": "all",
      "windows": {
        "wix": {
          "license": "../../../LICENSE"
        },
        "nsis": {
          "license": "../../../LICENSE"
        }
      }
    },
    "security": {
      "csp": null
    },
    "windows": [
      {
        "fullscreen": false,
        "height": 800,
        "resizable": true,
        "title": "OpenRFID Simulator - RFIDSoftwares",
        "width": 1200
      }
    ]
  }
}
