{
  "name": "@openrfid/shell",
  "version": "1.0.0",
  "description": "Shared React views shell for OpenRFID Simulator.",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts",
    "dev": "tsup src/index.ts --format cjs,esm --dts --watch",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@openrfid/core": "workspace:*",
    "@openrfid/plugin-api": "workspace:*",
    "@openrfid/readers": "workspace:*",
    "@openrfid/simulator": "workspace:*",
    "@openrfid/tags": "workspace:*",
    "@openrfid/ui": "workspace:*",
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "@types/react": "^18.2.66",
    "@types/react-dom": "^18.2.22",
    "tsup": "^8.0.2",
    "typescript": "^5.4.5"
  },
  "publishConfig": {
    "access": "public"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/rfidsoftwares/openrfid-simulator.git"
  },
  "bugs": {
    "url": "https://github.com/rfidsoftwares/openrfid-simulator/issues"
  },
  "homepage": "https://rfidsoftwares.com"
}
